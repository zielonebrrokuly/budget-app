# Skopiuj ten plik do .env i uzupełnij wartości.

# Connection string do bazy Postgres (np. Neon: https://neon.tech — darmowy plan wystarcza).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Opcjonalnie: ustaw hasło, aby włączyć ekran logowania. Bez tej zmiennej logowanie jest wyłączone.
# APP_PASSWORD="twoje-haslo"
